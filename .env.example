# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Admin protection
# Use the same comma-separated Supabase Auth email(s) in both variables.
ADMIN_EMAILS=your_admin_email@example.com
NEXT_PUBLIC_ADMIN_EMAILS=your_admin_email@example.com

# DeepSeek AI (text analysis) — server-side, preferred over Settings panel
DEEPSEEK_API_KEY=your_deepseek_api_key

# Qwen Vision AI (OCR) — server-side, preferred over Settings panel
QWEN_API_KEY=your_qwen_api_key
