# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Public site URL used by SEO metadata, robots.txt, and sitemap.xml
NEXT_PUBLIC_SITE_URL=https://www.a3ter1a.cn

# Admin protection
# Comma-separated Supabase Auth email(s) allowed to use server-only admin APIs.
ADMIN_EMAILS=your_admin_email@example.com

# DeepSeek AI (text analysis) — server-side, preferred over Settings panel
DEEPSEEK_API_KEY=your_deepseek_api_key

# Qwen Vision AI (OCR) — server-side, preferred over Settings panel
QWEN_API_KEY=your_qwen_api_key
